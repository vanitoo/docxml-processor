# Optimized XSLT Processor Dockerfile
# Base size: ~100MB (vs ~656MB original)

FROM mcr.microsoft.com/dotnet/sdk:8.0-alpine AS build
ARG BUILD_CONFIGURATION=Release
ARG VERSION
RUN echo $VERSION > ./VERSION
WORKDIR /source

# Install build dependencies
RUN apk add --no-cache curl

# Copy only necessary .csproj files for caching
COPY ./ProcessingCommon/ProcessingCommon.csproj ./ProcessingCommon/
COPY ./XsltProcessor/XsltProcessor.csproj ./XsltProcessor/

# Copy VERSION too, because csproj expects it at /source/VERSION
COPY ./VERSION ./VERSION

# Restore dependencies
RUN dotnet restore XsltProcessor/XsltProcessor.csproj

# Copy only necessary source code after restore
COPY ./ProcessingCommon ./ProcessingCommon/
COPY ./XsltProcessor ./XsltProcessor/

WORKDIR /source/XsltProcessor
RUN dotnet publish XsltProcessor.csproj -c $BUILD_CONFIGURATION -o /app --no-restore

# Remove unnecessary files
RUN rm -rf /app/*.pdb /app/*.xml 2>/dev/null || true

FROM mcr.microsoft.com/dotnet/aspnet:8.0-alpine AS runtime
WORKDIR /app

# Install runtime dependencies
RUN apk add --no-cache \
    icu-libs \
    libgdiplus \
    ca-certificates \
    tzdata

COPY --from=build /app ./
COPY ./XsltProcessor/appsettings.json ./

# Ensure xsd and xslt folders are copied
COPY ./XsltProcessor/xsd/ ./xsd/
COPY ./XsltProcessor/xslt/ ./xslt/

ENTRYPOINT ["dotnet", "XsltProcessor.dll"]