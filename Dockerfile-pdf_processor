FROM mcr.microsoft.com/dotnet/sdk:7.0-alpine AS build
ARG BUILD_CONFIGURATION=Release
WORKDIR /source

COPY ./ProcessingCommon/ProcessingCommon.csproj ./ProcessingCommon/
COPY ./PdfProcessor/PdfProcessor.csproj ./PdfProcessor/

RUN dotnet restore PdfProcessor/PdfProcessor.csproj

COPY ./ProcessingCommon ./ProcessingCommon/
COPY ./PdfProcessor ./PdfProcessor/

WORKDIR /source/PdfProcessor
RUN dotnet publish -c $BUILD_CONFIGURATION -o /app --no-restore /p:UseAppHost=false && \
    find /app -name "*.pdb" -delete && \
    find /app -name "*.xml" -delete

FROM ghcr.io/surnet/alpine-wkhtmltopdf:3.23.2-0.12.6-full AS wkhtmltopdf

FROM mcr.microsoft.com/dotnet/aspnet:7.0-alpine AS runtime
WORKDIR /app

RUN apk add --no-cache \
    icu-libs \
    libgdiplus \
    ca-certificates \
    tzdata \
    libstdc++ \
    libgcc \
    zlib \
    fontconfig \
    freetype \
    libx11 \
    libxext \
    libxrender \
    ttf-freefont

COPY --from=build /app ./
COPY ./PdfProcessor/appsettings.json ./

COPY --from=wkhtmltopdf /bin/wkhtmltopdf /usr/local/bin/wkhtmltopdf
COPY --from=wkhtmltopdf /bin/wkhtmltoimage /usr/local/bin/wkhtmltoimage
COPY --from=wkhtmltopdf /lib/libwkhtmltox* /lib/

RUN chmod +x /usr/local/bin/wkhtmltopdf /usr/local/bin/wkhtmltoimage && \
    ln -sf /lib/libwkhtmltox.so /usr/lib/libwkhtmltox.so || true

ENTRYPOINT ["dotnet", "PdfProcessor.dll"]

