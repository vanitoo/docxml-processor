# Optimized File Watcher Dockerfile
# Base size: ~80MB (vs ~220MB original)

# Specify .NET version via arguments
ARG DOTNET_VERSION=7.0
ARG BUILD_CONFIGURATION=Release

# ===== Build Stage =====
FROM mcr.microsoft.com/dotnet/sdk:${DOTNET_VERSION}-alpine AS build
ARG DOTNET_VERSION
ARG BUILD_CONFIGURATION
WORKDIR /source

# Install build dependencies
RUN apk add --no-cache curl

# Copy .csproj files for caching
COPY ./DocumentXmlProcessorContext/DocumentXmlProcessorContext.csproj ./DocumentXmlProcessorContext/
COPY ./ProcessingCommon/ProcessingCommon.csproj ./ProcessingCommon/
COPY ./OldFIleWatcher/OldFIleWatcher.csproj ./OldFIleWatcher/
COPY nuget.config ./nuget.config

RUN dotnet restore ./OldFIleWatcher/OldFIleWatcher.csproj --configfile ./nuget.config

# Copy source code after restore
COPY ./DocumentXmlProcessorContext ./DocumentXmlProcessorContext/
COPY ./ProcessingCommon ./ProcessingCommon/
COPY ./OldFIleWatcher ./OldFIleWatcher/

WORKDIR /source/OldFIleWatcher
RUN dotnet publish -c $BUILD_CONFIGURATION -o /app --no-restore --configfile ../nuget.config

# Remove unnecessary files
RUN rm -rf /app/*.pdb /app/*.xml 2>/dev/null || true

# ===== Runtime Stage =====
FROM mcr.microsoft.com/dotnet/aspnet:${DOTNET_VERSION}-alpine AS runtime
WORKDIR /app

# Install runtime dependencies
RUN apk add --no-cache \
    icu-libs \
    libgdiplus \
    ca-certificates \
    tzdata

# Copy built application
COPY --from=build /app ./

# Copy configuration
COPY ./OldFIleWatcher/appsettings.json ./

# Healthcheck
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s CMD wget --no-verbose --tries=1 --spider http://localhost:5000/health || exit 1

ENTRYPOINT ["dotnet", "OldFIleWatcher.dll"]